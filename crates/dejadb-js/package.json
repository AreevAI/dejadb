{
  "name": "dejadb",
  "version": "1.0.0",
  "description": "Node.js bindings for DejaDB, the embedded memory engine for AI agents.",
  "license": "MIT OR Apache-2.0",
  "author": "MindGryd Software Private Limited",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AreevAI/dejadb.git"
  },
  "homepage": "https://github.com/AreevAI/dejadb",
  "keywords": ["memory", "ai-agents", "llm", "napi-rs", "bindings"],
  "main": "index.js",
  "types": "index.d.ts",
  "files": ["index.js", "index.d.ts", "LICENSE-MIT", "LICENSE-APACHE"],
  "engines": {
    "node": ">= 18"
  },
  "napi": {
